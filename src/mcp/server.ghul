namespace MCP is
    use System.Text.Json.JsonElement;
    use Collections.LIST;

    class SERVER is
        PROTOCOL_VERSION: string static => "2025-06-18";

        _reader: IO.TextReader;
        _writer: IO.TextWriter;
        _tools: LIST[TOOL];

        name: string;
        version: string;

        init(reader: IO.TextReader, writer: IO.TextWriter, name: string, version: string) is
            _reader = reader;
            _writer = writer;
            _tools = LIST[TOOL]();

            self.name = name;
            self.version = version;
        si

        add_tool(tool: TOOL) is
            _tools.add(tool);
        si

        // Serve until end of input.
        run() is
            do
                let request: REQUEST? mut;

                try
                    request = WIRE.read_request(_reader);
                catch ex: System.Text.Json.JsonException
                    WIRE.write(_writer, ERROR_RESPONSE(WIRE.null_id, -32700, "parse error: {ex.message}"));
                    continue;
                yrt

                if !request? then
                    break;
                fi

                handle(request);
            od
        si

        handle(request: REQUEST) is
            let method = request.method;

            if !method? then
                reply_error(request, -32600, "invalid request: no method");
            elif method =~ "initialize" then
                reply(request, INITIALIZE_RESULT(PROTOCOL_VERSION, SERVER_INFO(name, version)));
            elif method =~ "ping" then
                reply(request, EMPTY());
            elif method =~ "tools/list" then
                reply(request, TOOLS_LIST_RESULT(_tools));
            elif method =~ "tools/call" then
                handle_tool_call(request);
            elif request.is_notification then
                // notifications we don't act on, e.g. notifications/initialized
            else
                reply_error(request, -32601, "method not found: {method}");
            fi
        si

        handle_tool_call(request: REQUEST) is
            let name = WIRE.try_get_string(request.params, "name");

            if !name? then
                reply_error(request, -32602, "tools/call requires a tool name");
                return;
            fi

            let tool = find_tool(name);

            if !tool? then
                reply_error(request, -32602, "unknown tool: {name}");
                return;
            fi

            let arguments = WIRE.try_get_element(request.params, "arguments");

            try
                reply(request, CALL_RESULT(tool.call(arguments), false));
            catch ex: System.Exception
                // Tool failures are results, not protocol errors, so the
                // model calling the tool sees the message.
                reply(request, CALL_RESULT("{name} failed: {ex.message}", true));
            yrt
        si

        find_tool(name: string) -> TOOL? is
            for tool in _tools do
                if tool.name =~ name then
                    return tool;
                fi
            od

            return null;
        si

        reply(request: REQUEST, result: object) is
            if request.is_notification then
                return;
            fi

            WIRE.write(_writer, RESPONSE(request.id, result));
        si

        reply_error(request: REQUEST, code: int, message: string) is
            if request.is_notification then
                return;
            fi

            WIRE.write(_writer, ERROR_RESPONSE(request.id, code, message));
        si
    si

    class INITIALIZE_RESULT is
        protocol_version: string public;
        capabilities: CAPABILITIES public;
        server_info: SERVER_INFO public;

        init(protocol_version: string, server_info: SERVER_INFO) is
            self.protocol_version = protocol_version;
            capabilities = CAPABILITIES();
            self.server_info = server_info;
        si
    si

    class CAPABILITIES is
        tools: EMPTY public;

        init() is
            tools = EMPTY();
        si
    si

    class SERVER_INFO is
        name: string public;
        version: string public;

        init(name: string, version: string) is
            self.name = name;
            self.version = version;
        si
    si

    class EMPTY is
        init() is si
    si

    class TOOLS_LIST_RESULT is
        tools: LIST[TOOL] public;

        init(tools: LIST[TOOL]) is
            self.tools = tools;
        si
    si

    class CALL_RESULT is
        content: CONTENT_ITEM[] public;
        is_error: bool public;

        init(text: string, is_error: bool) is
            content = [CONTENT_ITEM(text)];
            self.is_error = is_error;
        si
    si

    class CONTENT_ITEM is
        type: string public;
        text: string public;

        init(text: string) is
            type = "text";
            self.text = text;
        si
    si
si
